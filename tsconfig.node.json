{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "target": "ES2020",
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "otools-plugin-sdk": ["otools-plugin-sdk/src/index.ts"],
      "otools-plugin-sdk/*": ["otools-plugin-sdk/src/*"]
    },
    "types": [
      "node"
    ]
  },
  "include": [
    "vite.config.ts",
    "vitest.config.ts"
  ]
}
